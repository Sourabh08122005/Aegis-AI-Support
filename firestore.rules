rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Ticket rules
    match /tickets/{ticketId} {
      allow get: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidTicket(request.resource.data) && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isValidTicket(request.resource.data) && (isOwner(resource.data.userId) || isAdmin()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'subject'])
      );
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && isValidMessage(request.resource.data) && (get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid || isAdmin());
      }
    }

    // Admin check
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'chakravortysourabh08@gmail.com'
      );
    }

    // Validation helpers
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidTicket(data) {
      return data.keys().hasAll(['userId', 'status', 'createdAt', 'updatedAt', 'subject']) &&
             data.keys().size() == 5 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.status in ['open', 'closed'] &&
             data.subject is string && data.subject.size() <= 200 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['ticketId', 'role', 'content', 'timestamp']) &&
             data.keys().size() >= 4 &&
             data.ticketId == ticketId &&
             data.role in ['user', 'assistant', 'system'] &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp == request.time;
    }

    // Logs & Metrics
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // In a real app, you'd restrict this to a backend-only key or specific rules
    }

    match /metrics/{metricId} {
      allow read: if isAdmin();
    }
  }
}
